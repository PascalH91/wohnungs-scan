# =============================================================================
# Environment variable reference for Wohnungs-Scan.
#
# How env files are used here:
#   .env                  → shared, non-secret defaults. COMMITTED to git.
#   .env.production       → non-secret production overrides. COMMITTED to git.
#   .env.local            → your local secrets/overrides. GIT-IGNORED.
#   .env.production.local → server secrets/overrides. GIT-IGNORED (create on VPS).
#
# Later files override earlier ones. NEVER put secrets (RESEND_API_KEY, etc.)
# in .env or .env.production — they are committed. Put them in a .local file.
# Do NOT set NODE_ENV — Next.js manages it automatically.
# =============================================================================

# Server port. Also used by the scheduler to reach its own /api routes.
PORT=8080

# --- Apartment filtering criteria -------------------------------------------
NEXT_PUBLIC_MIN_ROOM_SIZE=80
NEXT_PUBLIC_MIN_ROOM_NUMBER=3
NEXT_PUBLIC_MAX_COLD_RENT=1900
NEXT_PUBLIC_MAX_WARM_RENT=2000

# --- Scraper configuration --------------------------------------------------
SCRAPER_DEFAULT_TIMEOUT=60000
SCRAPER_SELECTOR_TIMEOUT=5000
SCRAPER_NAVIGATION_TIMEOUT=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=2000

# Block images/media/fonts during scraping to save bandwidth (default: enabled).
# Set to false only if a provider needs the full page rendered.
SCRAPER_BLOCK_RESOURCES=true

# --- Browser pool -----------------------------------------------------------
BROWSER_POOL_MIN=1
BROWSER_POOL_MAX=5
BROWSER_POOL_IDLE_TIMEOUT=300000
BROWSER_POOL_ACQUIRE_TIMEOUT=30000

# --- Background scheduler (unattended scraping + email) ---------------------
# Set to "true" ONLY where you want the loop to run (.env.production.local on
# the server, or .env.local to test). Keep false in committed files.
ENABLE_SCHEDULER=false
# Wait between full scrape passes (default 10 min) plus random extra jitter, so
# the cadence isn't perfectly regular (a bot signal). Raise these to be gentler.
SCRAPE_INTERVAL_MS=600000
SCRAPE_INTERVAL_JITTER_MS=180000
# Randomized wait between individual providers within a pass — never burst.
PROVIDER_GAP_MS=5000
PROVIDER_GAP_JITTER_MS=10000
# If a provider rate-limits/blocks us, stop hitting it for this long (default 1h).
BLOCK_COOLDOWN_MS=3600000

# --- Email notifications via Resend (https://resend.com) — SECRET -----------
# Belongs in a .local file only.
RESEND_API_KEY=
NOTIFY_EMAIL_TO=you@example.com
NOTIFY_EMAIL_FROM=Wohnungs-Scan <onboarding@resend.dev>

# --- Chromium binary path (Docker / VPS) — environment-specific -------------
# Belongs in .env.production.local. Leave empty locally — locate-chrome finds
# your browser automatically.
PUPPETEER_EXECUTABLE_PATH=

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_ENABLE_CONSOLE=true
